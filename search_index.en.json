f":0,"i":{"docs":{},"df":0,"c":{"docs":{},"df":0,"i":{"docs":{"https://berdandy.com/privacy/":{"tf":1.0}},"df":1}}}}},"r":{"docs":{},"df":0,"i":{"docs":{},"df":0,"v":{"docs":{},"df":0,"a":{"docs":{},"df":0,"c":{"docs":{},"df":0,"i":{"docs":{"https://berdandy.com/privacy/":{"tf":1.0}},"df":1}}}}}}},"w":{"docs":{},"df":0,"e":{"docs":{},"df":0,"d":{"docs":{"https://berdandy.com/blog/goldsmithing/":{"tf":1.0}},"df":1}},"h":{"docs":{},"df":0,"i":{"docs":{},"df":0,"m":{"docs":{"https://berdandy.com/blog/goldsmithing/":{"tf":1.0}},"df":1}}}}}}},"documentStore":{"save":true,"docs":{"https://berdandy.com/":{"body":"Berdandy's Obsessions\nThis site is dedicated to my various obsessions, hobbies and work. I make all of this stuff.\n","description":"","id":"https://berdandy.com/","title":""},"https://berdandy.com/blog/":{"body":"","description":"","id":"https://berdandy.com/blog/","title":""},"https://berdandy.com/blog/goldsmithing/":{"body":"When I decided to ask Rachel if she wanted to get married, I wanted something unique and personal for an\nengagement ring. With the audacity of curiosity, I wandered into a local goldsmith's\nshop with the intention of asking for some advice on how to explore making the engagement ring\nmyself.\nSerendipity was with me that day, because it turned out that Jason had previously taught workshops,\nbut hadn't in several years. He was open to doing some custom lessons about lost-wax casting.\nFast-forward several months, a few dozen lunchtime lessons later, and I had created an\nengagement ring in my own custom claddagh design\n \n... and two wedding bands with line work that evokes a similar feeling:\n \n","description":"","id":"https://berdandy.com/blog/goldsmithing/","title":"Whims for a Wedding"},"https://berdandy.com/blog/hobbiesofhobbies/":{"body":"It's hobbies, all the way down...\nI make games professionally, and most of my hobbies are creative endeavours. And even some of my hobbies\nhave progressed into semi-professional status.\nTo some degree, I guess my true hobby is collecting hobbies. And then with enough time, they turn into\nskills and careers.\nThe goal for this site is to have a home on the internet that can unify all this stuff in a single location, instead of going to This Place for music works, That Place for tabletop design works, The Other Place for video game works, The Fourth Place for physical crafting works, and so on and so on.\nIt's likely to be a little chaotic, but with a throughline of creativity.\nEnjoy.\n","description":"About this site... and myself.","id":"https://berdandy.com/blog/hobbiesofhobbies/","title":"Hobbies of hobbies"},"https://berdandy.com/contact/":{"body":"Want to get in touch? Fill out the form below to send me a message and I will get back to you as soon as possible!\n\n  \n    Name\n    \n  \n  \n    Email Address\n    \n  \n  \n    Message\n    \n  \n  \n  \n    Send\n  \n\n","description":"To reach us please use the contact form on this page.","id":"https://berdandy.com/contact/","title":"Contact"},"https://berdandy.com/images/":{"body":"","description":"","id":"https://berdandy.com/images/","title":""},"https://berdandy.com/offline/":{"body":"Offline Mode\nSorry, no cache found and it looks like you’re offline, a connection is required.\n","description":"","id":"https://berdandy.com/offline/","title":"Offline Mode"},"https://berdandy.com/pages/":{"body":"","description":"","id":"https://berdandy.com/pages/","title":""},"https://berdandy.com/pages/craft/":{"body":"Physicalia\nWith my careers and hobbies involving ephemeral creativity -- video game development, photography,\nmusic production, web development, etc -- sometimes, I feel a pressure to create something tangible\nand physical.\nHere lies a simple gallery of some of my works. Everything here was created by my own hand.\n\n\n\n\n\n\n    \n      \n    \n    \n      \n    \n    \n      \n    \n    \n      \n    \n    \n      \n    \n\n","description":"Gallery of some crafting projects","id":"https://berdandy.com/pages/craft/","title":"Handicraft Gallery"},"https://berdandy.com/privacy/":{"body":"Privacy\n\nThis site does not set or use cookies.\nThis site does not store data in the browser to be shared, sent, or sold to third-parties.\nNo personal information is shared, sent, or sold to third-parties.\nGo away.\n\nEffective Date: 1st Jan 2025\n","description":"This page outlines the Privacy Policy for this site, and the date at which this policy was put into affect.","id":"https://berdandy.com/privacy/","title":"Privacy Policy"}},"docInfo":{"https://berdandy.com/":{"body":10,"description":0,"title":0},"https://berdandy.com/blog/":{"body":0,"description":0,"title":0},"https://berdandy.com/blog/goldsmithing/":{"body":66,"description":0,"title":2},"https://berdandy.com/blog/hobbiesofhobbies/":{"body":59,"description":2,"title":2},"https://berdandy.com/contact/":{"body":16,"description":6,"title":1},"https://berdandy.com/images/":{"body":0,"description":0,"title":0},"https://berdandy.com/offline/":{"body":10,"description":0,"title":2},"https://berdandy.com/pages/":{"body":0,"description":0,"title":0},"https://berdandy.com/pages/craft/":{"body":31,"description":3,"title":2},"https://berdandy.com/privacy/":{"body":28,"description":9,"title":2}},"length":10},"lang":"English"}